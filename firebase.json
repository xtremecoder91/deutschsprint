{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "setup-assets.sh",
      "*.md"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/deutschsprint-3d.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(fbx|glb|gltf|hdr|exr)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}
